{
  "name": "gradient-puzzle",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "feedback:serve:dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "feedback:serve:preview": "VITE_ENABLE_QA_BOOTSTRAP=1 vite build && vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "feedback:capture": "node scripts/runFeedback.mjs capture dev",
    "feedback:ci": "node scripts/runFeedback.mjs ci preview",
    "feedback:update-baselines": "node scripts/updateFeedbackBaselines.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "TMPDIR=/tmp vitest run",
    "test:coverage": "TMPDIR=/tmp vitest run --coverage",
    "test:watch": "TMPDIR=/tmp vitest",
    "catalog:generate": "vite-node scripts/generatePublishedCatalog.ts",
    "research:trajectory": "vite-node scripts/trajectorySweep.ts",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
